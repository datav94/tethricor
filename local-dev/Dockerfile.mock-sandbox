# Local test double for the agent-runtime. Includes git for repoUrl clone support.
FROM python:3.12

# RUN apt-get update \
#     && apt-get install -y --no-install-recommends git \
#     && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY mock_sandbox.py .

EXPOSE 8080
CMD ["python", "mock_sandbox.py"]
